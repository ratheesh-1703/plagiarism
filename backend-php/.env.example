APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
LOG_DIR=storage/logs

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=plagiarism_db
DB_USER=root
DB_PASS=

JWT_SECRET=CHANGE_THIS_TO_A_32_PLUS_CHARACTER_SECRET_VALUE
JWT_EXPIRES_HOURS=24
JWT_ISSUER=plagiarism-api
JWT_AUDIENCE=plagiarism-client

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=8
RATE_LIMIT_DIR=storage/cache/ratelimits

PLAGIARISM_THRESHOLD=0.72
MAX_UPLOAD_MB=15
UPLOAD_DIR=storage/uploads
REPORT_DIR=storage/reports

# Optional published-source APIs for deeper IEEE/Scopus coverage
IEEE_API_KEY=
SCOPUS_API_KEY=
